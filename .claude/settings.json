{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); [ -n \"$f\" ] && npx @biomejs/biome check --fix --unsafe \"$f\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *pnpm-lock*) echo 'BLOCK: Do not edit lock files directly. Use pnpm install.' >&2; exit 1 ;; esac"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "c=$(jq -r '.tool_input.command // empty'); case \"$c\" in *\"git merge\"*) echo 'BLOCK: git merge is not allowed. Use PRs instead.' >&2; exit 1 ;; esac"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "c=$(jq -r '.tool_input.command // empty'); case \"$c\" in *\"git push\"*) case \"$c\" in *main*|*master*|*production*|*prod*) echo 'BLOCK: Push to protected branches [main/master/production/prod] is not allowed. Push to a feature branch instead.' >&2; exit 1 ;; esac ;; esac"
          }
        ]
      }
    ],
   "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts/claude/session-end-checkpoint.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts/claude/session-end-checkpoint.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm format)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git tag:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo:*)",
      "Bash(gh api:*)"
    ],
    "deny": [
      "Bash(git merge:*)",
      "Bash(git push *main*)",
      "Bash(git push *master*)",
      "Bash(git push *prod*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)"
    ]
  }
}
